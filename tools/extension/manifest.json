{
    "manifest_version": 3,
    "name": "Slopblock Zero",
    "version": "1.0.0.2",
    "description": "Block AI-Generated Content on Every Platform",
    "action": {
      "default_icon": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "64": "icons/icon64.png",
        "128": "icons/icon128.png"
      },
      "default_title": "Slopblock Zero"
    },
    "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "permissions": ["tabs", "webNavigation"],
    "host_permissions": [
      "*://twitter.com/*",
      "*://x.com/*",
      "*://m.tiktok.com/*",
      "*://www.tiktok.com/*",
      "*://tiktok.com/*",
      "*://m.facebook.com/*",
      "*://www.facebook.com/*",
      "*://facebook.com/*",
      "*://m.instagram.com/*",
      "*://www.instagram.com/*",
      "*://instagram.com/*",
      "*://www.linkedin.com/*",
      "*://linkedin.com/*",
      "*://m.youtube.com/*",
      "*://www.youtube.com/*",
      "*://youtube.com/*",
      "*://old.reddit.com/*",
      "*://www.reddit.com/*",
      "*://reddit.com/*",
      "*://m.pinterest.com/*",
      "*://www.pinterest.com/*",
      "*://pinterest.com/*"
    ],
    "background": {
      "service_worker": "background.js",
      "type": "module"
    },
    "content_scripts": [
      {
        "matches": [
          "*://twitter.com/*",
          "*://x.com/*",
          "*://tiktok.com/*",
          "*://m.tiktok.com/*",
          "*://www.tiktok.com/*",
          "*://facebook.com/*",
          "*://m.facebook.com/*",
          "*://www.facebook.com/*",
          "*://instagram.com/*",
          "*://m.instagram.com/*",
          "*://www.instagram.com/*",
          "*://linkedin.com/*",
          "*://www.linkedin.com/*",
          "*://youtube.com/*",
          "*://m.youtube.com/*",
          "*://www.youtube.com/*",
          "*://reddit.com/*",
          "*://old.reddit.com/*",
          "*://www.reddit.com/*",
          "*://pinterest.com/*",
          "*://m.pinterest.com/*",
          "*://www.pinterest.com/*"
        ],
        "js": ["contentScript.js"]
      }
    ]
}
